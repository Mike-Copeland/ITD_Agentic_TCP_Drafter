    "archiver": "^7.0.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "dxf-writer": "^1.18.4",
    "express": "^4.21.2",
    "firebase": "^12.11.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pdfkit": "^0.18.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
